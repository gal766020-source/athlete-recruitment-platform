PORT=3001

# PostgreSQL connection string (Supabase, Neon, Railway, etc.)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# JWT — change this to a long random string in production
JWT_SECRET=arp-dev-secret-change-in-production

# Default admin credentials (seeded on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# OpenAI — enables AI reasoning + outreach drafts (falls back to deterministic if absent)
OPENAI_API_KEY=

# US Dept of Education College Scorecard — enriches tuition/SAT data (optional, free key at api.data.gov)
COLLEGE_SCORECARD_API_KEY=

# Resend — enables direct email sending (optional, free tier at resend.com — 3,000 emails/month)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# CORS — comma-separated list of allowed frontend origins
# e.g. https://arp-tennis.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
